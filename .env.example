# =============================================================================
# CognitiveBaseAI — Evidence-based Scientific Reasoning Engine
# Copy this file to .env (or .env.dev/.env.prod) and fill placeholders.
# DO NOT commit .env files with real secrets — only this .env.example.
# =============================================================================

# ---------------------- Domains (used by Traefik) ---------------------------
KB_DOMAIN=localhost
KB_ALT_DOMAIN=localhost
KB_DEV_DOMAIN=localhost
KB_DEV_ALT_DOMAIN=localhost
LETSENCRYPT_EMAIL=admin@example.com

# ---------------------- Application environment -----------------------------
APP_ENV=dev
ENV_FILE=.env

# ---------------------- PostgreSQL ------------------------------------------
POSTGRES_USER=cognitive
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=cognitive_kb
PG_DSN=postgresql+psycopg2://cognitive:changeme_postgres@postgres:5432/cognitive_kb
DB_WAIT_TIMEOUT=60
DB_WAIT_INTERVAL=2
SKIP_MIGRATIONS=false

# ---------------------- Neo4j -----------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j

# ---------------------- Persistence toggles ---------------------------------
# Архитектура сфокусирована на двух хранилищах: PostgreSQL (источник истины)
# и Neo4j (граф знаний). При недоступности любого из них pipeline
# graceful-fallback'ом продолжает работу in-memory.
PERSISTENCE_ENABLED=true
PERSISTENCE_POSTGRES=true
PERSISTENCE_NEO4J=true

# ---------------------- Embedding service -----------------------------------
# Modes: auto | sentence-transformer | deterministic
EMBEDDING_MODE=auto
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ---------------------- Knowledge extraction (LLM via OpenRouter) -----------
# EXTRACTION_MODE controls how scientific entities + claims are extracted:
#   rules   — deterministic regex + ontology heuristics only (no API cost)
#   llm     — LLM-only via OpenRouter (rule-based fallback on failure)
#   hybrid  — LLM-primary + rule-based safety net (recommended for production)
EXTRACTION_MODE=hybrid
# Set to true if you want the demo bootstrap corpus to also be extracted by
# the LLM. Defaults to false so test_demo_coverage stays deterministic and
# container restarts don't re-pay OpenRouter tokens.
EXTRACTION_LLM_ON_DEMO=false
EXTRACTION_LLM_TIMEOUT=60
EXTRACTION_LLM_MAX_RETRIES=2

# ---------------------- Hybrid retrieval weights (TZ §3.7) ------------------
# hybrid_score = α·keyword + β·semantic + γ·graph + δ·claim_confidence
#              + ε·evidence_strength + ζ·source_reliability − η·contradiction_risk
HYBRID_ALPHA=0.15
HYBRID_BETA=0.35
HYBRID_GAMMA=0.20
HYBRID_DELTA=0.10
HYBRID_EPSILON=0.15
HYBRID_ZETA=0.05
HYBRID_ETA=0.10

# ---------------------- OpenRouter / LLM ------------------------------------
# When OPENROUTER_API_KEY + OPENROUTER_MODEL are set AND EXTRACTION_MODE is
# llm or hybrid, the pipeline uses the LLM to produce ScientificClaim v2
# records (subject-predicate-object-condition + evidence) and inter-claim
# relations. Recommended models: anthropic/claude-3.5-sonnet,
# openai/gpt-4o-mini, anthropic/claude-3-haiku.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_HTTP_REFERER=https://github.com/anthropics/claude-code
OPENROUTER_APP_TITLE=CognitiveBaseAI

# ---------------------- Auth / Security -------------------------------------
JWT_SECRET_KEY=change_me_with_32_byte_random_value
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
ADMIN_API_KEY=
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_me_strong_password

# ---------------------- Frontend --------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# ---------------------- Observability ---------------------------------------
PROMETHEUS_ENABLED=false
CORS_ALLOW_ORIGINS=http://localhost:5173
